.auth-page {
  min-height: 100vh;
  overflow-x: hidden;
  background: linear-gradient(180deg, #eef6ff 0%, #f7fbff 48%, #f4f6f8 100%);
  color: #1f2f46;
}

.auth-shell {
  min-height: 100vh;
  padding: 86rpx 28rpx 56rpx;
  box-sizing: border-box;
}

.auth-header {
  padding: 34rpx 20rpx 38rpx;
  text-align: center;
}

.auth-title {
  color: #101828;
  font-size: 54rpx;
  font-weight: 800;
  line-height: 1.16;
  letter-spacing: 1rpx;
}

.auth-subtitle {
  margin-top: 20rpx;
  color: #1558a8;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 46rpx;
}

.auth-desc {
  margin-top: 14rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.5;
}

.auth-card {
  margin-top: 18rpx;
  padding: 0 30rpx;
  overflow: hidden;
  border: 1rpx solid rgba(226, 235, 247, 0.9);
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 42rpx rgba(31, 72, 116, 0.07);
  box-sizing: border-box;
}

.field-row {
  display: flex;
  align-items: center;
  min-height: 108rpx;
  border-bottom: 1rpx solid #edf4fb;
}

.field-row:last-child {
  border-bottom: none;
}

.field-label {
  flex: 1;
  min-width: 0;
  color: #344960;
  font-size: 28rpx;
  font-weight: 600;
}

.field-input {
  width: 300rpx;
  min-height: 88rpx;
  color: #1f2f46;
  font-size: 28rpx;
  text-align: right;
}

.input-placeholder {
  color: #a8bfd8;
}

.auth-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  margin-top: 46rpx;
  padding: 0;
  border: none;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #37c6c3 0%, #1677ff 100%);
  box-shadow: 0 14rpx 28rpx rgba(22, 119, 255, 0.22);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
  text-align: center;
}

.auth-button::after {
  border: none;
}

.auth-button:active {
  opacity: 0.88;
}

.auth-footer {
  margin-top: 34rpx;
  color: #8b9aae;
  font-size: 24rpx;
  line-height: 36rpx;
  text-align: center;
}
