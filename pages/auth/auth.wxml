<view class="auth-page">
  <view class="auth-shell">
    <view class="auth-header">
      <view class="auth-title">知心小助手</view>
      <view class="auth-subtitle">员工身份验证</view>
      <view class="auth-desc">请输入工号和手机号后 4 位完成验证</view>
    </view>

    <view class="auth-card">
      <view class="field-row">
        <view class="field-label">工号</view>
        <input
          class="field-input"
          type="text"
          value="{{employeeNo}}"
          placeholder="请输入工号"
          placeholder-class="input-placeholder"
          bindinput="onEmployeeNoInput"
        />
      </view>

      <view class="field-row">
        <view class="field-label">手机号后 4 位</view>
        <input
          class="field-input"
          type="number"
          maxlength="4"
          value="{{phoneLast4}}"
          placeholder="请输入手机号后 4 位"
          placeholder-class="input-placeholder"
          bindinput="onPhoneLast4Input"
        />
      </view>
    </view>

    <button class="auth-button" bindtap="verifyIdentity">进入小程序</button>

    <view class="auth-footer">仅限内部员工使用</view>
  </view>
</view>
