.index-page {
  background: linear-gradient(180deg, #edf5ff 0%, #f7f9fc 48%, #f4f7fb 100%);
}

.hero {
  padding: 32rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #ffffff 0%, #eaf4ff 100%);
}

.brand-row {
  display: flex;
  align-items: center;
}

.logo-placeholder {
  width: 112rpx;
  height: 112rpx;
  border: 2rpx dashed #7aa7d9;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.68);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-placeholder-text {
  color: #1769e0;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.bank-info {
  margin-left: 20rpx;
}

.bank-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.bank-subtitle {
  margin-top: 8rpx;
  color: #8b95a1;
  font-size: 22rpx;
}

.hero-main {
  margin-top: 50rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-text {
  flex: 1;
  padding-right: 24rpx;
}

.title {
  color: #111827;
  font-size: 56rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.subtitle {
  margin-top: 18rpx;
  color: #5f6b7a;
  font-size: 30rpx;
}

.mascot-placeholder {
  width: 172rpx;
  height: 188rpx;
  border: 2rpx dashed #7fd4de;
  border-radius: 54rpx 54rpx 40rpx 40rpx;
  background: linear-gradient(180deg, rgba(238, 252, 255, 0.96), rgba(215, 247, 255, 0.86));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #1596a6;
  box-shadow: 0 18rpx 40rpx rgba(36, 169, 205, 0.14);
}

.mascot-placeholder-head {
  width: 66rpx;
  height: 66rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 2rpx solid rgba(21, 150, 166, 0.18);
}

.mascot-placeholder-body {
  margin-top: 14rpx;
  width: 112rpx;
  text-align: center;
  font-size: 22rpx;
  line-height: 1.35;
}

.business-section {
  margin-top: 34rpx;
}

.section-title {
  margin-bottom: 22rpx;
  color: #172033;
  font-size: 32rpx;
  font-weight: 700;
}

.business-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -11rpx;
}

.business-card {
  width: calc(50% - 22rpx);
  min-height: 220rpx;
  margin: 11rpx;
  padding: 30rpx 24rpx;
}

.business-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 22rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 68rpx;
  text-align: center;
}

.business-icon.blue {
  background: linear-gradient(135deg, #3692ff, #075de1);
}

.business-icon.green {
  background: linear-gradient(135deg, #55d26f, #159447);
}

.business-icon.orange {
  background: linear-gradient(135deg, #ffb15d, #f06b21);
}

.business-icon.gold {
  background: linear-gradient(135deg, #ffd86b, #d69a00);
}

.business-name {
  margin-top: 24rpx;
  color: #172033;
  font-size: 32rpx;
  font-weight: 700;
}

.business-desc {
  margin-top: 10rpx;
  color: #7b8794;
  font-size: 24rpx;
  line-height: 1.5;
}
