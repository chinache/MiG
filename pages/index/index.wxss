.index-page {
  min-height: 100vh;
  padding-top: 28rpx;
  background: linear-gradient(180deg, #edf6ff 0%, #f6f9fd 46%, #f4f7fb 100%);
}

.hero-card {
  position: relative;
  min-height: 428rpx;
  padding: 30rpx 30rpx 42rpx;
  overflow: hidden;
  background: linear-gradient(140deg, #f7fcff 0%, #dff1ff 54%, #cbe8ff 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 38rpx;
  box-shadow: 0 22rpx 54rpx rgba(52, 111, 173, 0.13);
}

.hero-card::after {
  content: '';
  position: absolute;
  left: -72rpx;
  right: -72rpx;
  bottom: -122rpx;
  height: 190rpx;
  border-radius: 50% 50% 0 0;
  background: rgba(255, 255, 255, 0.56);
}

.hero-glow {
  position: absolute;
  border-radius: 50%;
  opacity: 0.7;
}

.hero-glow-left {
  left: -56rpx;
  top: 150rpx;
  width: 210rpx;
  height: 210rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.92) 0%, rgba(255, 255, 255, 0) 70%);
}

.hero-glow-right {
  right: -82rpx;
  top: -70rpx;
  width: 260rpx;
  height: 260rpx;
  background: radial-gradient(circle, rgba(97, 202, 233, 0.36) 0%, rgba(97, 202, 233, 0) 68%);
}

.brand-area {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  width: 236rpx;
  height: 66rpx;
}

.brand-logo-fallback {
  position: absolute;
  left: 0;
  top: 8rpx;
  width: 220rpx;
  height: 46rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(224, 243, 255, 0.88));
  box-shadow: inset 0 0 0 1rpx rgba(80, 143, 199, 0.08);
}

.brand-logo-fallback::before {
  content: '';
  position: absolute;
  left: 14rpx;
  top: 9rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0b68b7 0%, #0b68b7 50%, #16a05a 51%, #16a05a 100%);
}

.brand-logo-fallback::after {
  content: '';
  position: absolute;
  left: 54rpx;
  top: 15rpx;
  width: 132rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(35, 71, 102, 0.24), rgba(48, 178, 184, 0.18));
}

.brand-logo {
  position: relative;
  z-index: 1;
  width: 236rpx;
  height: 58rpx;
}

.hero-content {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

.hero-kicker {
  display: inline-block;
  height: 42rpx;
  line-height: 42rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #2b78bd;
  font-size: 22rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(64, 130, 188, 0.08);
}

.title {
  margin-top: 30rpx;
  color: #111d33;
  font-size: 62rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  line-height: 1.08;
}

.subtitle {
  margin-top: 20rpx;
  color: #5f7188;
  font-size: 30rpx;
  line-height: 1.4;
}

.mascot-area {
  position: relative;
  width: 248rpx;
  height: 292rpx;
  margin-right: -12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mascot-halo {
  position: absolute;
  right: 6rpx;
  bottom: 26rpx;
  width: 212rpx;
  height: 212rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.98) 0%, rgba(233, 251, 255, 0.82) 52%, rgba(255, 255, 255, 0) 72%);
  box-shadow: 0 18rpx 42rpx rgba(36, 169, 205, 0.15);
}

.mascot-fallback {
  position: absolute;
  z-index: 1;
  right: 20rpx;
  bottom: 18rpx;
  width: 178rpx;
  height: 214rpx;
  border-radius: 88rpx 88rpx 70rpx 70rpx;
  background: linear-gradient(180deg, #a9f3f1 0%, #5bcdd0 100%);
  box-shadow: 0 18rpx 32rpx rgba(37, 120, 151, 0.12);
}

.mascot-fallback-head {
  position: absolute;
  left: 37rpx;
  top: 34rpx;
  width: 104rpx;
  height: 92rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
}

.mascot-fallback-body {
  position: absolute;
  left: 54rpx;
  bottom: 28rpx;
  width: 70rpx;
  height: 62rpx;
  border-radius: 36rpx 36rpx 30rpx 30rpx;
  background: rgba(255, 255, 255, 0.82);
}

.mascot-image {
  position: relative;
  z-index: 2;
  width: 246rpx;
  height: 292rpx;
}

.hero-wave {
  position: absolute;
  z-index: 1;
  left: 26rpx;
  bottom: 42rpx;
  width: 310rpx;
  height: 54rpx;
  border-bottom: 8rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 0 0 50% 50%;
  transform: rotate(-4deg);
}

.business-section {
  margin-top: 36rpx;
}

.section-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.section-title {
  color: #172033;
  font-size: 34rpx;
  font-weight: 800;
}

.section-subtitle {
  color: #8a97a8;
  font-size: 22rpx;
}

.business-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -12rpx;
}

.business-card {
  position: relative;
  width: calc(50% - 24rpx);
  min-height: 236rpx;
  margin: 12rpx;
  padding: 30rpx 26rpx 28rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 16rpx 42rpx rgba(35, 73, 118, 0.08);
  border: 1rpx solid rgba(226, 235, 248, 0.82);
}

.business-card::after {
  content: '';
  position: absolute;
  right: 24rpx;
  top: 28rpx;
  width: 14rpx;
  height: 14rpx;
  border-top: 3rpx solid #c9d4e5;
  border-right: 3rpx solid #c9d4e5;
  transform: rotate(45deg);
}

.business-card-hover {
  opacity: 0.9;
  transform: scale(0.985);
}

.business-icon {
  width: 78rpx;
  height: 78rpx;
  border-radius: 26rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 78rpx;
  text-align: center;
  box-shadow: 0 14rpx 28rpx rgba(49, 105, 175, 0.16);
}

.business-icon.blue {
  background: linear-gradient(135deg, #6fb2ff 0%, #1f73e8 100%);
}

.business-icon.green {
  background: linear-gradient(135deg, #79dc93 0%, #25a95a 100%);
}

.business-icon.purple {
  background: linear-gradient(135deg, #a895ff 0%, #7557e8 100%);
}

.business-icon.gold {
  background: linear-gradient(135deg, #ffd66e 0%, #e2a51b 100%);
}

.business-name {
  margin-top: 24rpx;
  color: #172033;
  font-size: 32rpx;
  font-weight: 800;
}

.business-desc {
  margin-top: 10rpx;
  color: #8a97a8;
  font-size: 24rpx;
  line-height: 1.5;
}

.footer {
  margin-top: 42rpx;
  color: #a0aabd;
  font-size: 22rpx;
}
