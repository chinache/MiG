.index-page {
  min-height: 100vh;
  padding: 0 24rpx 42rpx;
  background: linear-gradient(180deg, #eef6ff 0%, #f7fbff 46%, #f5f8fc 100%);
}

.hero {
  position: relative;
  min-height: 364rpx;
  margin: 0 -24rpx;
  padding: 34rpx 34rpx 46rpx;
  overflow: hidden;
  background: linear-gradient(145deg, #f8fcff 0%, #dff2ff 52%, #ccecff 100%);
  border-radius: 0 0 44rpx 44rpx;
}

.hero::after {
  position: absolute;
  right: -76rpx;
  bottom: -112rpx;
  width: 390rpx;
  height: 260rpx;
  content: '';
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.42);
}

.hero-cloud {
  position: absolute;
  z-index: 0;
  height: 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
}

.hero-cloud-left {
  left: -24rpx;
  bottom: 76rpx;
  width: 198rpx;
  box-shadow: 70rpx -18rpx 0 rgba(255, 255, 255, 0.48);
}

.hero-cloud-right {
  right: 210rpx;
  bottom: 110rpx;
  width: 116rpx;
  opacity: 0.72;
  box-shadow: 48rpx 16rpx 0 rgba(255, 255, 255, 0.52);
}

.brand-row,
.hero-main {
  position: relative;
  z-index: 1;
}

.brand-row {
  display: flex;
  align-items: center;
}

.logo-mark {
  width: 216rpx;
  height: 62rpx;
  padding: 4rpx 0;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.56);
}

.logo-image {
  display: block;
  width: 100%;
  height: 100%;
}

.hero-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 44rpx;
}

.hero-text {
  flex: 1;
  padding-right: 20rpx;
}

.title {
  color: #101828;
  font-size: 54rpx;
  font-weight: 800;
  line-height: 1.16;
  letter-spacing: 1rpx;
}

.subtitle {
  margin-top: 18rpx;
  color: #667085;
  font-size: 28rpx;
  line-height: 1.5;
}

.mascot-scene {
  position: relative;
  width: 214rpx;
  height: 220rpx;
  margin-right: 8rpx;
}

.mascot-glow {
  position: absolute;
  right: 14rpx;
  bottom: 12rpx;
  width: 152rpx;
  height: 42rpx;
  border-radius: 50%;
  background: rgba(45, 171, 198, 0.18);
}

.mascot-image {
  position: relative;
  z-index: 1;
  display: block;
  width: 100%;
  height: 100%;
}

.mascot-fallback {
  position: absolute;
  right: 28rpx;
  bottom: 24rpx;
  z-index: 1;
  width: 126rpx;
  height: 156rpx;
}

.mascot-fallback-head {
  width: 94rpx;
  height: 82rpx;
  margin: 0 auto;
  border: 8rpx solid #65d4df;
  border-radius: 46rpx 46rpx 38rpx 38rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 28rpx rgba(34, 154, 181, 0.12);
}

.mascot-fallback-body {
  width: 82rpx;
  height: 78rpx;
  margin: -4rpx auto 0;
  border-radius: 34rpx 34rpx 42rpx 42rpx;
  background: linear-gradient(180deg, #76dce7 0%, #39bdc9 100%);
}

.mascot-fallback-tail {
  position: absolute;
  right: 0;
  bottom: 34rpx;
  width: 42rpx;
  height: 62rpx;
  border: 8rpx solid #58cfd9;
  border-left: 0;
  border-radius: 0 42rpx 42rpx 0;
}

.business-section {
  position: relative;
  z-index: 2;
  margin-top: -26rpx;
}

.business-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -10rpx;
}

.business-card {
  width: calc(50% - 20rpx);
  min-height: 220rpx;
  margin: 10rpx;
  padding: 30rpx 22rpx 28rpx;
  text-align: center;
  background: #ffffff;
  border: 1rpx solid rgba(226, 235, 247, 0.9);
  border-radius: 26rpx;
  box-shadow: 0 12rpx 30rpx rgba(47, 92, 139, 0.08);
}

.business-card:active {
  transform: scale(0.98);
  opacity: 0.92;
}

.business-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 78rpx;
  height: 78rpx;
  margin: 0 auto;
  border-radius: 24rpx;
}

.business-icon-symbol {
  width: 58rpx;
  height: 58rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 58rpx;
  text-align: center;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.16);
}

.business-icon.blue {
  background: linear-gradient(145deg, #79b7ff 0%, #1f74f2 100%);
  box-shadow: 0 12rpx 24rpx rgba(36, 121, 242, 0.18);
}

.business-icon.green {
  background: linear-gradient(145deg, #7fdc83 0%, #31a852 100%);
  box-shadow: 0 12rpx 24rpx rgba(49, 168, 82, 0.18);
}

.business-icon.purple {
  background: linear-gradient(145deg, #b5a5ff 0%, #7458e8 100%);
  box-shadow: 0 12rpx 24rpx rgba(116, 88, 232, 0.18);
}

.business-icon.gold {
  background: linear-gradient(145deg, #ffd86a 0%, #e6a914 100%);
  box-shadow: 0 12rpx 24rpx rgba(214, 154, 0, 0.16);
}

.business-name {
  margin-top: 22rpx;
  color: #1d2939;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.35;
}

.business-desc {
  margin-top: 8rpx;
  color: #7a8797;
  font-size: 22rpx;
  line-height: 1.45;
}

.footer {
  margin-top: 42rpx;
  color: #8a95a5;
  font-size: 23rpx;
}
