<view class="container index-page">
  <view class="hero card">
    <view class="brand-row">
      <view class="logo-placeholder">
        <view class="logo-placeholder-text">LOGO</view>
      </view>
      <view class="bank-info">
        <view class="bank-name">龙泉农商银行</view>
        <view class="bank-subtitle">logo 占位区域</view>
      </view>
    </view>

    <view class="hero-main">
      <view class="hero-text">
        <view class="title">知心小助手</view>
        <view class="subtitle">一键测算 更清晰</view>
      </view>
      <view class="mascot-placeholder">
        <view class="mascot-placeholder-head"></view>
        <view class="mascot-placeholder-body">吉祥物占位</view>
      </view>
    </view>
  </view>

  <view class="business-section">
    <view class="section-title">请选择业务类型</view>
    <view class="business-grid">
      <view wx:for="{{businessEntries}}" wx:key="key" class="business-card card" data-url="{{item.url}}" bindtap="goBusiness">
        <view class="business-icon {{item.theme}}">{{item.icon}}</view>
        <view class="business-name">{{item.name}}</view>
        <view class="business-desc">{{item.desc}}</view>
      </view>
    </view>
  </view>

  <view class="footer">知心小助手 · 龙泉农商银行内部工具</view>
</view>
