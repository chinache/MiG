<view class="container index-page">
  <view class="hero-card card">
    <view class="hero-glow hero-glow-left"></view>
    <view class="hero-glow hero-glow-right"></view>

    <view class="brand-area">
      <view class="brand-logo-fallback"></view>
      <image wx:if="{{showBrandLogo}}" class="brand-logo" src="/assets/images/logo.png" mode="aspectFit" binderror="onBrandLogoError" />
    </view>

    <view class="hero-content">
      <view class="hero-copy">
        <view class="hero-kicker">绩效薪酬测算工具</view>
        <view class="title">知心小助手</view>
        <view class="subtitle">一键测算 更清晰</view>
      </view>

      <view class="mascot-area">
        <view class="mascot-halo"></view>
        <view class="mascot-fallback">
          <view class="mascot-fallback-head"></view>
          <view class="mascot-fallback-body"></view>
        </view>
        <image wx:if="{{showMascot}}" class="mascot-image" src="/assets/images/mascot.png" mode="aspectFit" binderror="onMascotError" />
      </view>
    </view>

    <view class="hero-wave"></view>
  </view>

  <view class="business-section">
    <view class="section-heading">
      <view class="section-title">业务薪酬测算</view>
      <view class="section-subtitle">选择业务类型，进入专属测算页</view>
    </view>

    <view class="business-grid">
      <view wx:for="{{businessEntries}}" wx:key="key" class="business-card card" hover-class="business-card-hover" data-url="{{item.url}}" bindtap="goBusiness">
        <view class="business-icon {{item.theme}}">{{item.icon}}</view>
        <view class="business-name">{{item.name}}</view>
        <view class="business-desc">{{item.desc}}</view>
      </view>
    </view>
  </view>

  <view class="footer">知心小助手 · 龙泉农商银行内部工具</view>
</view>
