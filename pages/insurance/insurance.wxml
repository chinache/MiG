<view class="insurance-page">
  <view class="insurance-shell">
    <view class="insurance-nav-title">保险薪酬</view>

    <view class="hero-card">
      <view class="hero-copy">
        <view class="hero-title">测算保险业务收入</view>
        <view class="hero-subtitle">全面专业  轻松测算</view>
      </view>
      <view class="mascot-box">
        <view class="mascot-placeholder">
          <view class="mascot-shield">✓</view>
        </view>
      </view>
    </view>

    <view class="product-tabs">
      <view
        wx:for="{{products}}"
        wx:key="key"
        class="product-tab {{selectedProduct === item.key ? 'active' : ''}}"
        data-key="{{item.key}}"
        bindtap="onProductTap"
      >{{item.name}}</view>
    </view>

    <view class="form-card">
      <view class="field-row option-row">
        <view class="field-label">{{optionLabel}}</view>
        <view class="option-list">
          <view
            wx:for="{{currentOptions}}"
            wx:key="key"
            class="option-pill {{selectedOption === item.key ? 'active' : ''}}"
            data-key="{{item.key}}"
            bindtap="onOptionTap"
          >{{item.name}}</view>
        </view>
      </view>
      <view class="field-row">
        <view class="field-label">{{inputLabel}}</view>
        <input
          class="field-input"
          type="{{inputType}}"
          value="{{inputValue}}"
          placeholder="{{placeholder}}"
          placeholder-class="input-placeholder"
          bindinput="onInput"
        />
      </view>
    </view>

    <button class="calculate-button" bindtap="startCalc">立即测算</button>

    <view wx:if="{{resultVisible}}" class="result-card">
      <view class="result-title">预计薪酬收入（税前）</view>
      <view class="result-amount">￥ {{resultAmount}}</view>
      <view class="result-detail">{{resultDetail}}</view>
      <view class="result-time">测算时间：{{calculatedTime}}</view>
    </view>
  </view>
</view>
