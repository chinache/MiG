.insurance-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5efff 0%, #f8f7fc 42%, #f4f6f8 100%);
  color: #2c2540;
}

.insurance-shell {
  min-height: 100vh;
  padding: 24rpx 28rpx 56rpx;
}

.insurance-nav-title {
  margin-bottom: 22rpx;
  color: #1f2933;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 48rpx;
  text-align: center;
}

.hero-card {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 176rpx;
  padding: 34rpx 30rpx;
  overflow: hidden;
  border: 1rpx solid rgba(124, 82, 214, 0.24);
  border-radius: 28rpx;
  background: linear-gradient(135deg, #f7f0ff 0%, #eadfff 54%, #d9c8ff 100%);
  box-shadow: 0 18rpx 46rpx rgba(111, 71, 205, 0.12);
}

.hero-card::before {
  position: absolute;
  top: -90rpx;
  right: 48rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.48);
  content: '';
}

.hero-copy {
  position: relative;
  z-index: 1;
}

.hero-title {
  color: #6b3fd0;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 48rpx;
}

.hero-subtitle {
  margin-top: 16rpx;
  color: #7650c9;
  font-size: 25rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.mascot-box {
  position: relative;
  z-index: 1;
  display: flex;
  flex: 0 0 150rpx;
  align-items: center;
  justify-content: center;
  width: 150rpx;
  height: 140rpx;
  margin-left: 24rpx;
}

.mascot-placeholder {
  position: relative;
  width: 132rpx;
  height: 118rpx;
  border: 1rpx solid rgba(126, 87, 216, 0.2);
  border-radius: 44rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.78) 0%, rgba(214, 197, 255, 0.66) 100%);
  box-shadow: inset 0 0 28rpx rgba(255, 255, 255, 0.62), 0 12rpx 24rpx rgba(112, 74, 204, 0.12);
}

.mascot-placeholder::before,
.mascot-placeholder::after {
  position: absolute;
  top: 40rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #6b3fd0;
  content: '';
}

.mascot-placeholder::before {
  left: 38rpx;
}

.mascot-placeholder::after {
  right: 38rpx;
}

.mascot-shield {
  position: absolute;
  right: 18rpx;
  bottom: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 60rpx;
  border-radius: 12rpx 12rpx 24rpx 24rpx;
  background: linear-gradient(135deg, #9d7cff 0%, #6f42d7 100%);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
}

.product-tabs {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 28rpx;
}

.product-tab {
  display: flex;
  flex: 1;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  border-radius: 999rpx;
  background: #f0eef3;
  color: #5d5965;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
}

.product-tab.active {
  background: linear-gradient(135deg, #8f5cf5 0%, #6f42d7 100%);
  box-shadow: 0 12rpx 24rpx rgba(111, 66, 215, 0.22);
  color: #ffffff;
}

.form-card {
  margin-top: 28rpx;
  padding: 0 30rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 42rpx rgba(83, 58, 138, 0.07);
}

.field-row {
  display: flex;
  align-items: center;
  min-height: 104rpx;
  border-bottom: 1rpx solid #f0edf7;
}

.field-row:last-child {
  border-bottom: none;
}

.option-row {
  align-items: center;
  min-height: 126rpx;
}

.field-label {
  flex: 0 0 190rpx;
  color: #332a45;
  font-size: 28rpx;
  font-weight: 600;
}

.option-list {
  display: flex;
  flex: 1;
  justify-content: flex-end;
  gap: 12rpx;
}

.option-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 126rpx;
  height: 58rpx;
  padding: 0;
  box-sizing: border-box;
  border: 1rpx solid #e1ddec;
  border-radius: 999rpx;
  background: #ffffff;
  color: #66616f;
  font-size: 25rpx;
  font-weight: 600;
}

.option-pill.active {
  border-color: #7b4de3;
  background: #fbf8ff;
  color: #6f42d7;
}

.field-input {
  flex: 1;
  min-height: 88rpx;
  color: #2d263d;
  font-size: 28rpx;
  text-align: right;
}

.input-placeholder {
  color: #bdb7c8;
}

.calculate-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  margin-top: 34rpx;
  padding: 0;
  border: none;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #9b6cff 0%, #6f42d7 100%);
  box-shadow: 0 14rpx 28rpx rgba(111, 66, 215, 0.24);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
  text-align: center;
}

.calculate-button::after {
  border: none;
}

.calculate-button:active {
  opacity: 0.88;
}

.result-card {
  margin-top: 24rpx;
  padding: 30rpx 28rpx 32rpx;
  border: 1rpx solid rgba(137, 94, 230, 0.34);
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f7f1ff 0%, #fdfbff 100%);
  box-shadow: 0 16rpx 38rpx rgba(111, 66, 215, 0.1);
  text-align: center;
}

.result-title {
  color: #75698c;
  font-size: 24rpx;
  font-weight: 600;
}

.result-amount {
  margin-top: 12rpx;
  color: #6f42d7;
  font-size: 52rpx;
  font-weight: 800;
  line-height: 66rpx;
}

.result-detail {
  margin-top: 10rpx;
  color: #7650c9;
  font-size: 23rpx;
}

.result-time {
  margin-top: 14rpx;
  color: #9d94ad;
  font-size: 22rpx;
}
