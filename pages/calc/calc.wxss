.calc-page {
  padding-bottom: 64rpx;
}

.banner {
  min-height: 176rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.banner-title {
  font-size: 34rpx;
  font-weight: 800;
}

.banner-desc {
  margin-top: 14rpx;
  color: #64748b;
  font-size: 25rpx;
}

.banner-badge {
  width: 108rpx;
  height: 108rpx;
  border-radius: 34rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 108rpx;
  text-align: center;
  box-shadow: 0 12rpx 30rpx rgba(15, 95, 213, 0.18);
}

.product-tabs {
  margin-top: 26rpx;
  white-space: nowrap;
}

.tab-wrap {
  display: flex;
  min-width: 100%;
}

.product-tab {
  flex-shrink: 0;
  margin-right: 16rpx;
  padding: 18rpx 30rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #64748b;
  font-size: 27rpx;
  box-shadow: 0 8rpx 28rpx rgba(23, 56, 102, 0.06);
}

.product-tab.active {
  font-weight: 700;
  background: #eef6ff;
}

.form-card {
  margin-top: 24rpx;
  overflow: hidden;
}

.form-row {
  min-height: 102rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #eef1f5;
}

.form-row:last-child {
  border-bottom: none;
}

.label-wrap {
  width: 310rpx;
  display: flex;
  align-items: center;
}

.field-label {
  color: #273244;
  font-size: 29rpx;
  font-weight: 600;
}

.field-unit {
  color: #7b8794;
  font-size: 24rpx;
}

.required {
  margin-left: 6rpx;
  color: #ef4444;
}

.field-input {
  flex: 1;
  min-width: 0;
  color: #1f2937;
  font-size: 29rpx;
  text-align: right;
}

.input-placeholder {
  color: #b7c0cc;
}

.preview-card,
.tip-card {
  margin-top: 22rpx;
  padding: 24rpx 28rpx;
}

.preview-title,
.tip-title {
  color: #172033;
  font-size: 28rpx;
  font-weight: 700;
}

.preview-line,
.tip-text {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.6;
}

.button-group {
  margin-top: 30rpx;
}

.clear-button {
  margin-top: 18rpx;
}
