<view class="container calc-page">
  <view class="banner card" style="background: {{activeProduct.gradient}};">
    <view>
      <view class="banner-title" style="color: {{activeProduct.color}};">测算{{activeProduct.shortName}}业务收入</view>
      <view class="banner-desc">{{activeProduct.description}} · 本地快速测算</view>
    </view>
    <view class="banner-badge" style="background: {{activeProduct.color}};">{{activeProduct.shortName}}</view>
  </view>

  <scroll-view class="product-tabs" scroll-x="true" enable-flex="true">
    <view class="tab-wrap">
      <view wx:for="{{products}}" wx:key="key" class="{{item.tabClass}}" style="{{item.tabStyle}}" data-key="{{item.key}}" bindtap="switchProduct">
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <view class="form-card card">
    <view wx:for="{{activeFields}}" wx:key="key" class="form-row">
      <view class="label-wrap">
        <text class="field-label">{{item.label}}</text>
        <text class="field-unit">（{{item.unit}}）</text>
        <text wx:if="{{item.required}}" class="required">*</text>
      </view>
      <input class="field-input" type="digit" value="{{item.value}}" placeholder="{{item.placeholder}}" placeholder-class="input-placeholder" data-key="{{item.key}}" bindinput="onInput" />
    </view>
  </view>

  <view wx:if="{{amountPreview.length}}" class="preview-card card">
    <view class="preview-title">金额换算提示</view>
    <view wx:for="{{amountPreview}}" wx:key="*this" class="preview-line">{{item}}</view>
  </view>

  <view class="button-group">
    <button class="primary-button" bindtap="startCalc">开始测算</button>
    <button class="secondary-button clear-button" bindtap="clearInput">清空输入</button>
  </view>

  <view class="tip-card card">
    <view class="tip-title">填写提示</view>
    <view class="tip-text">金额类默认单位为元；户数、数量请填写整数；本页会自动读取最近一次测算输入。</view>
  </view>
</view>
