.business-page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  background: #f4f8ff;
}

.placeholder-card {
  padding: 56rpx 32rpx;
  border-radius: 28rpx;
  background: #ffffff;
  text-align: center;
  box-shadow: 0 16rpx 44rpx rgba(22, 105, 224, 0.08);
}

.placeholder-icon {
  width: 96rpx;
  height: 96rpx;
  margin: 0 auto 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #57a8ff, #1469ee);
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 96rpx;
}

.page-title {
  color: #172033;
  font-size: 42rpx;
  font-weight: 800;
}

.page-desc {
  margin-top: 16rpx;
  color: #7b8794;
  font-size: 26rpx;
}
