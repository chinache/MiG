.loan-page {
  min-height: 100vh;
  overflow-x: hidden;
  background: linear-gradient(180deg, #edf6ff 0%, #f6f9fd 42%, #f4f6f8 100%);
  color: #1f2f46;
}

.loan-shell {
  min-height: 100vh;
  padding: 24rpx 28rpx 56rpx;
  box-sizing: border-box;
}

.loan-nav-title {
  margin-bottom: 22rpx;
  color: #1f2933;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 48rpx;
  text-align: center;
}

.hero-card {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 176rpx;
  padding: 34rpx 30rpx;
  overflow: hidden;
  border: 1rpx solid rgba(59, 130, 246, 0.2);
  border-radius: 28rpx;
  background: linear-gradient(135deg, #f0f8ff 0%, #cfe9ff 54%, #8fc7ff 100%);
  box-shadow: 0 18rpx 46rpx rgba(37, 99, 235, 0.12);
  box-sizing: border-box;
}

.hero-card::before {
  position: absolute;
  top: -90rpx;
  right: 48rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.52);
  content: '';
}

.hero-copy {
  position: relative;
  z-index: 1;
  min-width: 0;
}

.hero-title {
  color: #1558a8;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 48rpx;
}

.hero-subtitle {
  margin-top: 16rpx;
  color: #2f78c9;
  font-size: 25rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.mascot-box {
  position: relative;
  z-index: 1;
  display: flex;
  flex: 0 0 150rpx;
  align-items: center;
  justify-content: center;
  width: 150rpx;
  height: 140rpx;
  margin-left: 24rpx;
}

.mascot-img {
  display: block;
  width: 150rpx;
  height: 140rpx;
}

.form-card {
  margin-top: 26rpx;
  padding: 0 30rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 42rpx rgba(31, 72, 116, 0.06);
  box-sizing: border-box;
}

.field-row {
  display: flex;
  align-items: center;
  min-height: 104rpx;
}

.field-row.with-border {
  border-top: 1rpx solid #edf4fb;
}

.field-label {
  flex: 1;
  min-width: 0;
  color: #344960;
  font-size: 28rpx;
  font-weight: 600;
}

.loan-input {
  width: 230rpx;
  min-height: 88rpx;
  color: #1f2f46;
  font-size: 28rpx;
  text-align: right;
}

.input-placeholder {
  color: #a8bfd8;
}

.calculate-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  margin-top: 46rpx;
  padding: 0;
  border: none;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #1677ff 100%);
  box-shadow: 0 14rpx 28rpx rgba(22, 119, 255, 0.22);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
  text-align: center;
}

.calculate-button::after {
  border: none;
}

.calculate-button:active {
  opacity: 0.88;
}

.result-card {
  margin-top: 24rpx;
  padding: 30rpx 28rpx 32rpx;
  border: 1rpx solid rgba(80, 156, 255, 0.32);
  border-radius: 24rpx;
  background: linear-gradient(180deg, #edf7ff 0%, #fbfdff 100%);
  box-shadow: 0 16rpx 38rpx rgba(37, 99, 235, 0.1);
  text-align: center;
  box-sizing: border-box;
}

.result-title {
  color: #58728f;
  font-size: 24rpx;
  font-weight: 600;
}

.result-amount {
  margin-top: 12rpx;
  color: #1677ff;
  font-size: 52rpx;
  font-weight: 800;
  line-height: 66rpx;
}

.result-detail {
  margin-top: 10rpx;
  color: #2f78c9;
  font-size: 23rpx;
  line-height: 34rpx;
}

.result-formula {
  margin-top: 8rpx;
  color: #6c88a6;
  font-size: 22rpx;
  line-height: 32rpx;
}

.result-time {
  margin-top: 14rpx;
  color: #8da5bd;
  font-size: 22rpx;
}
