.gold-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff8ea 0%, #f6f7fb 42%, #f4f6f8 100%);
  color: #2f2b24;
}

.gold-shell {
  min-height: 100vh;
  padding: 24rpx 28rpx 56rpx;
}

.gold-nav-title {
  margin-bottom: 22rpx;
  color: #1f2933;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 48rpx;
  text-align: center;
}

.hero-card {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 176rpx;
  padding: 34rpx 30rpx;
  overflow: hidden;
  border: 1rpx solid rgba(234, 181, 74, 0.28);
  border-radius: 28rpx;
  background: linear-gradient(135deg, #fff8df 0%, #ffeab1 54%, #ffd98a 100%);
  box-shadow: 0 18rpx 46rpx rgba(206, 137, 20, 0.12);
}

.hero-card::before {
  position: absolute;
  top: -90rpx;
  right: 48rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.48);
  content: '';
}

.hero-copy {
  position: relative;
  z-index: 1;
}

.hero-title {
  color: #8f5600;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 48rpx;
}

.hero-subtitle {
  margin-top: 16rpx;
  color: #b17a16;
  font-size: 25rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.mascot-box {
  position: relative;
  flex: 0 0 150rpx;
  width: 150rpx;
  height: 140rpx;
  margin-left: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
  }
.mascot-img {
    width: 150rpx;
    height: 140rpx;
    display: block;
    }

.mascot-halo {
  position: absolute;
  right: 4rpx;
  bottom: 4rpx;
  width: 120rpx;
  height: 104rpx;
  border-radius: 52rpx;
  background: linear-gradient(135deg, #e4fff7 0%, #9fe6da 100%);
}

.mascot-face {
  position: absolute;
  right: 22rpx;
  bottom: 18rpx;
  width: 86rpx;
  height: 76rpx;
  border: 4rpx solid #78d3ca;
  border-radius: 44rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 14rpx rgba(74, 159, 151, 0.16);
}

.mascot-ear {
  position: absolute;
  top: 12rpx;
  width: 24rpx;
  height: 34rpx;
  border-radius: 18rpx 18rpx 8rpx 8rpx;
  background: #77d8cf;
}

.mascot-ear.left {
  right: 86rpx;
  transform: rotate(-24deg);
}

.mascot-ear.right {
  right: 20rpx;
  transform: rotate(24deg);
}

.mascot-eye {
  position: absolute;
  top: 28rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #416f73;
}

.mascot-eye.left {
  left: 24rpx;
}

.mascot-eye.right {
  right: 24rpx;
}

.mascot-smile {
  position: absolute;
  left: 32rpx;
  top: 44rpx;
  width: 22rpx;
  height: 12rpx;
  border-bottom: 4rpx solid #f2a24f;
  border-radius: 0 0 22rpx 22rpx;
}

.form-card {
  margin-top: 26rpx;
  padding: 0 30rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 42rpx rgba(96, 82, 56, 0.06);
}

.field-row {
  display: flex;
  align-items: center;
  min-height: 104rpx;
}

.field-label {
  flex: 1;
  color: #4b4338;
  font-size: 28rpx;
  font-weight: 600;
}

.weight-input {
  width: 230rpx;
  min-height: 88rpx;
  color: #2d2a25;
  font-size: 28rpx;
  text-align: right;
}

.input-placeholder {
  color: #c9b58f;
}

.calculate-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  margin-top: 142rpx;
  padding: 0;
  border: none;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #e6a11b 0%, #c97a08 100%);
  box-shadow: 0 14rpx 28rpx rgba(207, 126, 8, 0.22);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
  text-align: center;
}

.calculate-button::after {
  border: none;
}

.calculate-button:active {
  opacity: 0.88;
}

.result-card {
  margin-top: 24rpx;
  padding: 30rpx 28rpx 32rpx;
  border: 1rpx solid rgba(229, 178, 84, 0.36);
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fff9e9 0%, #fffdf7 100%);
  box-shadow: 0 16rpx 38rpx rgba(214, 151, 45, 0.1);
  text-align: center;
}

.result-title {
  color: #7a6a52;
  font-size: 24rpx;
  font-weight: 600;
}

.result-amount {
  margin-top: 12rpx;
  color: #d4860b;
  font-size: 52rpx;
  font-weight: 800;
  line-height: 66rpx;
}

.result-detail {
  margin-top: 10rpx;
  color: #a2732a;
  font-size: 23rpx;
}

.result-time {
  margin-top: 14rpx;
  color: #b7a687;
  font-size: 22rpx;
}
