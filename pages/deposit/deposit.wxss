.deposit-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #edfdf5 0%, #f6f9f7 42%, #f4f6f8 100%);
  color: #1f352a;
}

.deposit-shell {
  min-height: 100vh;
  padding: 24rpx 28rpx 56rpx;
}

.deposit-nav-title {
  margin-bottom: 22rpx;
  color: #1f2933;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 48rpx;
  text-align: center;
}

.hero-card {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 176rpx;
  padding: 34rpx 30rpx;
  overflow: hidden;
  border: 1rpx solid rgba(40, 178, 111, 0.22);
  border-radius: 28rpx;
  background: linear-gradient(135deg, #ecfff5 0%, #c9f5dc 54%, #a9eccc 100%);
  box-shadow: 0 18rpx 46rpx rgba(18, 145, 83, 0.12);
}

.hero-card::before {
  position: absolute;
  top: -90rpx;
  right: 48rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.48);
  content: '';
}

.hero-copy {
  position: relative;
  z-index: 1;
}

.hero-title {
  color: #12814d;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 48rpx;
}

.hero-subtitle {
  margin-top: 16rpx;
  color: #2f9a68;
  font-size: 25rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.mascot-box {
  position: relative;
  flex: 0 0 142rpx;
  width: 142rpx;
  height: 132rpx;
  margin-left: 24rpx;
}

.mascot-halo {
  position: absolute;
  right: 4rpx;
  bottom: 4rpx;
  width: 120rpx;
  height: 104rpx;
  border-radius: 52rpx;
  background: linear-gradient(135deg, #e7fff8 0%, #8ee0d3 100%);
}

.mascot-face {
  position: absolute;
  right: 22rpx;
  bottom: 18rpx;
  width: 86rpx;
  height: 76rpx;
  border: 4rpx solid #55c7b8;
  border-radius: 44rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 14rpx rgba(42, 150, 139, 0.16);
}

.mascot-ear {
  position: absolute;
  top: 12rpx;
  width: 24rpx;
  height: 34rpx;
  border-radius: 18rpx 18rpx 8rpx 8rpx;
  background: #3cc9ad;
}

.mascot-ear.left {
  right: 86rpx;
  transform: rotate(-24deg);
}

.mascot-ear.right {
  right: 20rpx;
  transform: rotate(24deg);
}

.mascot-eye {
  position: absolute;
  top: 28rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #255d63;
}

.mascot-eye.left {
  left: 24rpx;
}

.mascot-eye.right {
  right: 24rpx;
}

.mascot-smile {
  position: absolute;
  left: 32rpx;
  top: 44rpx;
  width: 22rpx;
  height: 12rpx;
  border-bottom: 4rpx solid #23a866;
  border-radius: 0 0 22rpx 22rpx;
}

.form-card {
  margin-top: 26rpx;
  padding: 0 30rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 42rpx rgba(40, 112, 73, 0.06);
}

.field-row {
  display: flex;
  align-items: center;
  min-height: 104rpx;
  border-bottom: 1rpx solid #edf4ef;
}

.field-row:last-child {
  border-bottom: none;
}

.field-label {
  flex: 1;
  color: #314238;
  font-size: 28rpx;
  font-weight: 600;
}

.field-input {
  width: 230rpx;
  min-height: 88rpx;
  color: #26342d;
  font-size: 28rpx;
  text-align: right;
}

.input-placeholder {
  color: #b9c9bf;
}

.calculate-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  margin-top: 30rpx;
  padding: 0;
  border: none;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #50c96f 0%, #19a85d 100%);
  box-shadow: 0 14rpx 28rpx rgba(26, 168, 93, 0.22);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
  text-align: center;
}

.calculate-button::after {
  border: none;
}

.calculate-button:active {
  opacity: 0.88;
}

.result-card {
  margin-top: 24rpx;
  padding: 30rpx 28rpx 32rpx;
  border: 1rpx solid rgba(65, 194, 122, 0.34);
  border-radius: 24rpx;
  background: linear-gradient(180deg, #effdf5 0%, #fbfffd 100%);
  box-shadow: 0 16rpx 38rpx rgba(32, 172, 96, 0.1);
  text-align: center;
}

.result-title {
  color: #5d7467;
  font-size: 24rpx;
  font-weight: 600;
}

.result-amount {
  margin-top: 12rpx;
  color: #16a35f;
  font-size: 52rpx;
  font-weight: 800;
  line-height: 66rpx;
}

.result-detail {
  margin-top: 10rpx;
  color: #328661;
  font-size: 23rpx;
}

.result-time {
  margin-top: 14rpx;
  color: #94a99c;
  font-size: 22rpx;
}
