<view class="deposit-page">
  <view class="deposit-shell">
    <view class="deposit-nav-title">存款薪酬</view>

    <view class="hero-card">
      <view class="hero-copy">
        <view class="hero-title">测算存款业务收入</view>
        <view class="hero-subtitle">清晰透明  快速准确</view>
      </view>
      <view class="mascot-box">
      <image class="mascot-img" src="/assets/images/mascot-deposit.png" mode="aspectFit"></image>
      </view>
    </view>

    <view class="form-card">
      <view class="field-row">
        <view class="field-label">较年初增加量（万元）</view>
        <input
          class="field-input"
          type="digit"
          value="{{increaseWan}}"
          placeholder="请输入"
          placeholder-class="input-placeholder"
          data-key="increaseWan"
          bindinput="onInput"
        />
      </view>
      <view class="field-row">
        <view class="field-label">自营存款付息率（%）</view>
        <input
          class="field-input"
          type="digit"
          value="{{interestRate}}"
          placeholder="请输入"
          placeholder-class="input-placeholder"
          data-key="interestRate"
          bindinput="onInput"
        />
      </view>
    </view>

    <button class="calculate-button" bindtap="startCalc">立即测算</button>

    <view wx:if="{{resultVisible}}" class="result-card">
      <view class="result-title">预计薪酬收入（税前）</view>
      <view class="result-amount">￥ {{resultAmount}}</view>
      <view class="result-detail">较年初增加量 {{calculatedIncreaseWan}} 万元 × 计价系数 {{calculatedCoefficient}}%</view>
      <view class="result-time">测算时间：{{calculatedTime}}</view>
    </view>
  </view>
</view>
