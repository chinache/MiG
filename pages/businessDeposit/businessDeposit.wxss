.business-deposit-page {
  min-height: 100vh;
  overflow-x: hidden;
  background: linear-gradient(180deg, #ecfffb 0%, #f6fbfa 42%, #f4f6f8 100%);
  color: #153c3a;
}

.business-deposit-shell {
  min-height: 100vh;
  padding: 24rpx 28rpx 56rpx;
  box-sizing: border-box;
}

.business-deposit-nav-title {
  margin-bottom: 22rpx;
  color: #1f2933;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 48rpx;
  text-align: center;
}

.hero-card {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 176rpx;
  padding: 34rpx 30rpx;
  overflow: hidden;
  border: 1rpx solid rgba(15, 159, 154, 0.24);
  border-radius: 28rpx;
  background: linear-gradient(135deg, #f0fffb 0%, #c9f7ee 54%, #9be8de 100%);
  box-shadow: 0 18rpx 46rpx rgba(15, 159, 154, 0.12);
  box-sizing: border-box;
}

.hero-card::before {
  position: absolute;
  top: -90rpx;
  right: 48rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.52);
  content: '';
}

.hero-copy {
  position: relative;
  z-index: 1;
  min-width: 0;
}

.hero-title {
  color: #0f7f7a;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 48rpx;
}

.hero-subtitle {
  margin-top: 16rpx;
  color: #13958f;
  font-size: 25rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.mascot-box {
  position: relative;
  z-index: 1;
  display: flex;
  flex: 0 0 150rpx;
  align-items: center;
  justify-content: center;
  width: 150rpx;
  height: 140rpx;
  margin-left: 24rpx;
}

.mascot-img {
  display: block;
  width: 150rpx;
  height: 140rpx;
}

.data-card {
  margin-top: 26rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 42rpx rgba(15, 96, 92, 0.07);
  box-sizing: border-box;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 28rpx 30rpx 22rpx;
}

.card-title {
  color: #1d3b39;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.unit-badge {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border: 1rpx solid rgba(15, 159, 154, 0.24);
  border-radius: 999rpx;
  background: #f0fffb;
  color: #0f9f9a;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 32rpx;
}

.table-head {
  display: flex;
  align-items: center;
  min-height: 76rpx;
  padding: 0 30rpx;
  background: #ecfffb;
  color: #22706c;
  font-size: 25rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.table-cell {
  min-width: 0;
}

.name-cell {
  flex: 1;
}

.value-cell {
  flex: 0 0 210rpx;
  text-align: right;
}

.table-body {
  padding: 0 30rpx;
}

.table-row {
  display: flex;
  align-items: center;
  min-height: 112rpx;
  border-bottom: 1rpx solid #edf6f4;
}

.table-row:last-child {
  border-bottom: none;
}

.business-name-cell {
  display: flex;
  flex: 1;
  min-width: 0;
  align-items: center;
  padding-right: 18rpx;
  box-sizing: border-box;
}

.item-icon {
  display: flex;
  flex: 0 0 54rpx;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  background: #e6fbf7;
  color: #0f9f9a;
  font-size: 24rpx;
  font-weight: 800;
}

.item-name {
  min-width: 0;
  color: #2d4543;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 38rpx;
  word-break: break-all;
}

.item-value {
  flex: 0 0 170rpx;
  color: #0f9f9a;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 48rpx;
  text-align: right;
}

.tips-card {
  display: flex;
  align-items: flex-start;
  margin-top: 24rpx;
  padding: 26rpx 28rpx;
  border: 1rpx solid rgba(15, 159, 154, 0.18);
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f2fffc 0%, #ffffff 100%);
  box-shadow: 0 16rpx 38rpx rgba(15, 159, 154, 0.08);
  box-sizing: border-box;
}

.tips-icon {
  display: flex;
  flex: 0 0 38rpx;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  background: #dff8f4;
  color: #0f9f9a;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 38rpx;
}

.tips-text {
  flex: 1;
  min-width: 0;
  color: #4d625f;
  font-size: 25rpx;
  line-height: 38rpx;
}
