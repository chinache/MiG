<view class="business-deposit-page">
  <view class="business-deposit-shell">
    <view class="business-deposit-nav-title">业务带存</view>

    <view class="hero-card">
      <view class="hero-copy">
        <view class="hero-title">办理业务对存款的影响</view>
        <view class="hero-subtitle">直观展示  一目了然</view>
      </view>
      <view class="mascot-box">
        <image class="mascot-img" src="{{mascotSrc}}" mode="aspectFit" binderror="onMascotError"></image>
      </view>
    </view>

    <view class="data-card">
      <view class="card-head">
        <view class="card-title">业务带存参考值</view>
        <view class="unit-badge">单位：万元/户</view>
      </view>

      <view class="table-head">
        <view class="table-cell name-cell">业务指标</view>
        <view class="table-cell value-cell">每户新增存款</view>
      </view>

      <view class="table-body">
        <view wx:for="{{businessItems}}" wx:key="name" class="table-row">
          <view class="business-name-cell">
            <view class="item-icon">{{item.icon}}</view>
            <view class="item-name">{{item.name}}</view>
          </view>
          <view class="item-value">{{item.value}}</view>
        </view>
      </view>
    </view>

    <view class="tips-card">
      <view class="tips-icon">i</view>
      <view class="tips-text">以上为各项业务每户可带动的新增存款参考值。</view>
    </view>
  </view>
</view>
