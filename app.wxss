page {
  min-height: 100vh;
  background: #f4f7fb;
  color: #1f2937;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Arial, sans-serif;
  box-sizing: border-box;
}

view,
text,
input,
button {
  box-sizing: border-box;
}

.container {
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
}

.card {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 16rpx 48rpx rgba(23, 56, 102, 0.08);
}

.primary-button {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #1677ff, #0f5fd5);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.secondary-button {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 18rpx;
  background: #eef5ff;
  color: #1769e0;
  font-size: 30rpx;
  border: none;
}

button::after {
  border: none;
}

.footer {
  margin-top: 48rpx;
  text-align: center;
  color: #7b8794;
  font-size: 24rpx;
}
